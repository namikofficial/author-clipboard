#!/usr/bin/env bash
# Pre-commit hook: runs formatting check and clippy ONLY on staged Rust files.
# If no staged .rs files, skips checks entirely.
# Install: just setup-hooks

set -euo pipefail

# Get list of staged .rs files
STAGED_RS_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs' '*.toml')

if [ -z "$STAGED_RS_FILES" ]; then
    # No Rust files staged — skip checks
    exit 0
fi

echo "🔍 Running pre-commit checks on staged files..."

# Stash unstaged changes so we only check what's being committed
STASH_NAME="pre-commit-$(date +%s)"
git stash push --keep-index --quiet -m "$STASH_NAME" 2>/dev/null || true
STASHED=true

# Restore unstaged changes on exit (success or failure)
cleanup() {
    if [ "$STASHED" = true ]; then
        # Check if our stash still exists
        if git stash list | grep -q "$STASH_NAME"; then
            git stash pop --quiet 2>/dev/null || true
        fi
    fi
}
trap cleanup EXIT

# Check formatting (like prettier --check)
echo "  Checking formatting..."
if ! cargo fmt -- --check 2>/dev/null; then
    echo ""
    echo "❌ Formatting issues found in staged files!"
    echo "   Run 'cargo fmt' or 'just fmt' to fix."
    echo ""
    exit 1
fi

# Run clippy (like eslint)
echo "  Running clippy..."
if ! cargo clippy --all-targets --all-features -- -D warnings 2>/dev/null; then
    echo ""
    echo "❌ Clippy found issues in staged files!"
    echo "   Run 'cargo clippy --fix' or 'just lint-fix' to auto-fix."
    echo ""
    exit 1
fi

echo "✅ Pre-commit checks passed!"
