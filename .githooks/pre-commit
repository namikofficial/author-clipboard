#!/usr/bin/env bash
# Pre-commit hook: runs formatting check and clippy ONLY on staged Rust files.
# If no staged .rs/.toml files, skips checks entirely.
# Install: just setup-hooks

set -euo pipefail

# Get list of staged Rust-related files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs' '*.toml')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo "🔍 Running pre-commit checks on staged files..."

# Use git stash create + git checkout-index to test only staged content
# This avoids the merge conflict issues of git stash push/pop
STASH_HASH=$(git stash create)
if [ -n "$STASH_HASH" ]; then
    # Reset working tree to match the index (staged state)
    git checkout -- . 2>/dev/null || true
    NEEDS_RESTORE=true
else
    NEEDS_RESTORE=false
fi

restore_working_tree() {
    if [ "$NEEDS_RESTORE" = true ] && [ -n "$STASH_HASH" ]; then
        git stash apply "$STASH_HASH" --quiet 2>/dev/null || true
    fi
}
trap restore_working_tree EXIT

# Check formatting
echo "  Checking formatting..."
if ! cargo fmt -- --check 2>/dev/null; then
    echo ""
    echo "❌ Formatting issues found!"
    echo "   Run 'cargo fmt' or 'just fmt' to fix."
    echo ""
    exit 1
fi

# Run clippy
echo "  Running clippy..."
if ! cargo clippy --all-targets --all-features -- -D warnings 2>/dev/null; then
    echo ""
    echo "❌ Clippy found issues!"
    echo "   Run 'cargo clippy --fix' or 'just lint-fix' to auto-fix."
    echo ""
    exit 1
fi

echo "✅ Pre-commit checks passed!"
