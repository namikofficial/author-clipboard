# author-clipboard development configuration
# Copy to .env and customize: cp .env.example .env
# These values are loaded by the justfile automatically.

# ── Logging ───────────────────────────────────────────────────────────
# Options: error, warn, info, debug, trace
# Per-crate: author_clipboard_daemon=debug,author_clipboard_shared=info
RUST_LOG=info

# ── COSMIC / Wayland ─────────────────────────────────────────────────
# Required for clipboard monitoring on COSMIC desktop
COSMIC_DATA_CONTROL_ENABLED=1

# ── Build ─────────────────────────────────────────────────────────────
# Set to 1 for verbose cargo output
# CARGO_TERM_VERBOSE=1

# Set to "release" to run release builds via `just daemon` / `just applet`
# BUILD_PROFILE=debug
